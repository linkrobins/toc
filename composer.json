{
    "name": "linkrobins/toc",
    "description": "Auto-generated table of contents for Flarum posts. Builds anchors from Markdown headings (#, ##, ###) and renders an inline TOC at the top of each post that has 2+ headings.",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Karl Bullock",
            "email": "karl@linkrobins.com"
        }
    ],
    "keywords": ["flarum", "toc", "table-of-contents", "headings", "anchors"],
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "LinkRobins\\Toc\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Link Robins Table of Contents",
            "category": "feature",
            "icon": {
                "name": "fas fa-list-ol",
                "color": "#07adcc",
                "backgroundColor": "#1a2535"
            }
        }
    }
}
